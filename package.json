{
  "name": "fpv-lavet",
  "version": "0.0.0",
  "scripts": {
    "lint": "npm run lint:eslint && npm run lint:imports",
    "lint:eslint": "eslint \"src/**/*.ts\"",
    "lint:imports": "node scripts/check-import-aliases.mjs",
    "ng": "ng",
    "start": "ng serve",
    "build": "npm run lint && ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "serve:ssr:fpv-lavet": "node dist/fpv-lavet/server/server.mjs"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "packageManager": "npm@11.4.0",
  "dependencies": {
    "@angular/animations": "^21.2.9",
    "@angular/cdk": "21.2.7",
    "@angular/common": "^21.2.9",
    "@angular/compiler": "^21.2.9",
    "@angular/core": "^21.2.9",
    "@angular/forms": "^21.2.9",
    "@angular/material": "21.2.7",
    "@angular/platform-browser": "^21.2.9",
    "@angular/platform-server": "^21.2.9",
    "@angular/router": "^21.2.9",
    "@angular/ssr": "21.2.7",
    "@fdograph/rut-utilities": "^1.4.0",
    "bootstrap": "^5.3.8",
    "express": "^5.1.0",
    "rxjs": "~7.8.0",
    "sweetalert2": "^11.26.24",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "21.2.7",
    "@angular/cli": "21.2.7",
    "@angular/compiler-cli": "^21.2.9",
    "@types/express": "^5.0.1",
    "@types/jasmine": "~5.1.0",
    "@types/node": "^20.17.19",
    "@typescript-eslint/eslint-plugin": "^8.46.1",
    "@typescript-eslint/parser": "^8.46.1",
    "eslint": "^9.37.0",
    "jsdom": "^27.1.0",
    "typescript": "5.9.3",
    "vitest": "^4.0.8"
  }
}
